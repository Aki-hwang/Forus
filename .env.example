# 이 파일을 복사해 `.env.local` 을 만들고 값을 채우세요:  cp .env.example .env.local
# (.env.local 은 git에 커밋되지 않습니다. 운영 값은 Railway Variables 에 설정)

# ───────────────────────────────────────────────────────────────
# 인증 (Auth.js v5 / Google·Naver 소셜 로그인)
# ───────────────────────────────────────────────────────────────

# 세션(JWT) 암호화 비밀키.  생성: `npx auth secret` 또는 `openssl rand -base64 32`
AUTH_SECRET=

# 배포 환경의 사이트 주소(콜백 URL 기준). 로컬은 비워두면 http://localhost:3000.
# 예) https://forus-advertising.up.railway.app
# AUTH_URL=

# Google OAuth — https://console.cloud.google.com/apis/credentials 에서 발급
# 승인된 리디렉션 URI: {사이트}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ───────────────────────────────────────────────────────────────
# Apify — Meta(페이스북) 광고 라이브러리 수집 설정
# 토큰이 없으면 자동으로 목업 데이터로 폴백합니다.
# ───────────────────────────────────────────────────────────────

# (필수) Apify API 토큰 — https://console.apify.com/settings/integrations
APIFY_TOKEN=

# (선택) 사용할 액터. 기본값: curious_coder/facebook-ads-library-scraper
# APIFY_AD_ACTOR=curious_coder/facebook-ads-library-scraper

# (선택) 검색당 최대 수집(과금) 건수. 기본값: 60 (최소 10)
#   강남·명동·홍대 권역별 JP3+KR2+CN2 + 일반(시술) 8 = 검색 29회를 매 수집마다 전부 실행.
#   최대 약 (값 × 29)건 수집 → 중복·비의료·30일초과 제거 후 노출. 높이면 광고↑ 비용·시간↑
# APIFY_PER_QUERY=60

# (선택) 검색 동시 실행 수(Apify 동시 실행 한도 보호). 기본값: 6
# APIFY_CONCURRENCY=6

# (선택) 수집 시간 예산(ms). 라우트 제한(300s) 안에서 의료검증까지 끝내도록 예산 초과 시
#   남은 검색은 건너뛰고 모은 만큼 사용. 기본값: 210000 (210초)
# APIFY_COLLECT_MS=210000

# (선택) 수집 결과 캐시 TTL(초). 기본값: 604800 (7일 = 주 1회 갱신)
# APIFY_TTL_SECONDS=604800

# (선택) 집행 일수 상한(일). 이 일수를 초과해 오래 돌고 있는 광고는 제외(최신 트렌드만 노출).
# 시작일 미상 광고는 유지. 기본값: 30
# MAX_ACTIVE_DAYS=30

# --- 2단계: 인스타그램 조회수 보강 (apify/instagram-scraper) ---
# (선택) 광고주 계정당 가져올 게시물 수. 기본값: 8
# APIFY_IG_POSTS=8
# (선택) 한 번에 조회수 수집할 최대 계정 수. 기본값: 40
# APIFY_IG_PROFILES_CAP=40

# ───────────────────────────────────────────────────────────────
# 의료기관 검증 (네이버·카카오 지역검색) — 광고주가 실제 병원/의원인지 확인해
# 화장품·제품 등 비의료 광고를 제외합니다. (무료 API · Apify 비용과 무관)
# 키가 없으면 휴리스틱 필터로 폴백. 둘 중 가진 키만 넣어도 동작합니다.
# ───────────────────────────────────────────────────────────────

# 카카오 로컬 REST 키 — https://developers.kakao.com (앱 → 앱 키 → REST API 키)
KAKAO_REST_KEY=

# 네이버 지역검색(local) — https://developers.naver.com/apps (검색 API 사용 추가)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# (선택) 검증 결과 캐시 TTL(초). 기본값: 2592000 (30일 — 의료기관 상태는 잘 안 바뀜)
# CLINIC_VERIFY_TTL_SECONDS=2592000
