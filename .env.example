# 이 파일을 복사해 `.env.local` 을 만들고 값을 채우세요:  cp .env.example .env.local
# (.env.local 은 git에 커밋되지 않습니다. 운영 값은 Railway Variables 에 설정)

# ───────────────────────────────────────────────────────────────
# 인증 (Auth.js v5 / Google·Naver 소셜 로그인)
# ───────────────────────────────────────────────────────────────

# 세션(JWT) 암호화 비밀키.  생성: `npx auth secret` 또는 `openssl rand -base64 32`
AUTH_SECRET=

# 배포 환경의 사이트 주소(콜백 URL 기준). 로컬은 비워두면 http://localhost:3000.
# 예) https://forus-advertising.up.railway.app
# AUTH_URL=

# Google OAuth — https://console.cloud.google.com/apis/credentials 에서 발급
# 승인된 리디렉션 URI: {사이트}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ───────────────────────────────────────────────────────────────
# Apify — Meta(페이스북) 광고 라이브러리 수집 설정
# 토큰이 없으면 자동으로 목업 데이터로 폴백합니다.
# ───────────────────────────────────────────────────────────────

# (필수) Apify API 토큰 — https://console.apify.com/settings/integrations
APIFY_TOKEN=

# (선택) 사용할 액터. 기본값: curious_coder/facebook-ads-library-scraper
# APIFY_AD_ACTOR=curious_coder/facebook-ads-library-scraper

# --- 💰 수집 1회 예산 상한 (가장 중요한 비용 노브) ---
# 실제 수집(/api/collect, full=1)은 이 금액 안으로 수집량을 자동 조절합니다. 두 액터 모두
# 결과 1건당 과금이라 "건수 상한 = 비용 상한". 응답 JSON 의 estCostUsd 로 이번 수집 예상비용을
# 확인할 수 있습니다(상한 추정·실제는 보통 더 적음). 서빙은 스냅샷만 읽어 무료라 재배포·트래픽엔
# 과금이 없고, 오직 수집 버튼 클릭 때만 비용이 발생합니다.
# 기본값: 3 ($3/회). 운영: 월·금 주2회 자동수집 × ~$3 ≈ 월 $26 ($29 플랜 안). 깊게보다 자주.
# APIFY_BUDGET_USD=3
# (선택) 액터 1,000건당 단가($) — 예산 환산에 사용. 1차 수집 실측(추정 $6.36 → 실제 ≈ $3)에
#   맞춰 보정한 기본값. 실측이 또 어긋나면 조정.
#   광고: 기본 0.35 / 인스타(무료·조회수): 기본 1.27
# APIFY_AD_COST_PER_1K=0.35
# APIFY_IG_COST_PER_1K=1.27
# (선택) "이상적 풀수집" 목표치 — 예산이 넉넉하면 여기까지, 부족하면 비례 축소.
#   기본 목표치 예상비용 ≈ $6.04 ($7 예산 안. 광고 $2.94 + 무료 $2.72 + 조회수 $0.38)
#   (1차 수집 ~$3 대비 약 2배. 쿼리 70개·해시태그 17개가 상한이라 깊이로 키움)
#   광고 검색수·검색당건수 / 무료 프로필·프로필당 / 무료 해시태그·태그당 / 조회수 프로필·게시물
# APIFY_TARGET_QUERIES=70
# APIFY_TARGET_PER_QUERY=120
# APIFY_TARGET_ORG_PROFILES=80
# APIFY_TARGET_ORG_POSTS=14
# APIFY_TARGET_ORG_TAGS=17
# APIFY_TARGET_ORG_TAG_POSTS=60
# APIFY_TARGET_VIEW_PROFILES=50
# APIFY_TARGET_VIEW_POSTS=6

# (선택) 검색당 최대 수집(과금) 건수. 기본값: 40 (최소 10)
#   지역·일반 검색어를 송출국가로 확장(JP타겟=KR+JP, CN타겟=KR+TW, KR=KR) → 검색 70회.
#   (일본인 광고는 한국뿐 아니라 일본 송출분까지 검색해야 누락이 없어서 JP가 42/70로 가장 많음)
#   비용 가늠: 70회 × 40 ≈ 2,800건/수집. 쿼리 "다양성"이 100건+ 확보를 좌우하므로 같은 광고를
#   깊게 파기(높은 값)보다 넓게 훑는 게 dedup 후 고유 광고 확보에 유리·저렴. 무료 크레딧이면
#   과하게 올리지 말 것(재배포마다 캐시 리셋 → 재수집되어 크레딧 소진 빠름).
#   URL에 start_date[min]=(30일전)을 붙여 최근 광고만 우선 수집. 시간예산(COLLECT_MS)에 잘려도
#   라운드로빈으로 JP·권역이 앞쪽부터 커버됨. 높이면 광고↑ 비용·시간↑ (예산 초과분은 건너뜀)
# APIFY_PER_QUERY=40

# (선택) 검색 동시 실행 수(Apify 동시 실행 한도 보호). 기본값: 6
# APIFY_CONCURRENCY=6

# (선택) 수집 시간 예산(ms). 라우트 제한(300s) 안에서 의료검증까지 끝내도록 예산 초과 시
#   남은 검색은 건너뛰고 모은 만큼 사용. 기본값: 210000 (210초)
# APIFY_COLLECT_MS=210000

# (선택) 수집 결과 캐시 TTL(초). 기본값: 604800 (7일 = 주 1회 갱신)
# APIFY_TTL_SECONDS=604800

# (선택) 집행 일수 상한(일). 이 일수를 초과해 오래 돌고 있는 광고는 제외(최신 트렌드만 노출).
# 시작일 미상 광고는 유지. 기본값: 30
# MAX_ACTIVE_DAYS=30

# --- 2단계: 인스타그램 조회수 보강 (apify/instagram-scraper) ---
# (선택) 광고주 계정당 가져올 게시물 수. 기본값: 8
# APIFY_IG_POSTS=8
# (선택) 한 번에 조회수 수집할 최대 계정 수. 기본값: 40
# APIFY_IG_PROFILES_CAP=40

# ───────────────────────────────────────────────────────────────
# 의료기관 검증 (네이버·카카오 지역검색) — 광고주가 실제 병원/의원인지 확인해
# 화장품·제품 등 비의료 광고를 제외합니다. (무료 API · Apify 비용과 무관)
# 키가 없으면 휴리스틱 필터로 폴백. 둘 중 가진 키만 넣어도 동작합니다.
# ───────────────────────────────────────────────────────────────

# 카카오 로컬 REST 키 — https://developers.kakao.com (앱 → 앱 키 → REST API 키)
KAKAO_REST_KEY=

# 네이버 지역검색(local) — https://developers.naver.com/apps (검색 API 사용 추가)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# (선택) 검증 결과 캐시 TTL(초). 기본값: 2592000 (30일 — 의료기관 상태는 잘 안 바뀜)
# CLINIC_VERIFY_TTL_SECONDS=2592000
