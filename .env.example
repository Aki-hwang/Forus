# Apify 인스타그램 수집 설정
# 토큰이 없으면 자동으로 목업 데이터로 폴백합니다.

# (필수) Apify API 토큰 — https://console.apify.com/account/integrations
APIFY_TOKEN=

# (선택) 사용할 액터. 기본값: apify/instagram-scraper
# APIFY_INSTAGRAM_ACTOR=apify/instagram-scraper

# (선택) 계정당 수집 게시물 수. 기본값: 6
# APIFY_RESULTS_LIMIT=6

# (선택) 수집 결과 캐시 TTL(초). 기본값: 3600 (1시간)
# APIFY_TTL_SECONDS=3600

# (선택) 수집 대상 인스타 핸들을 콤마로 직접 지정 (미설정 시 src/lib/clinics.ts 기본 목록)
# APIFY_IG_PROFILES=raon_derma,celline_clinic,muse_clinic_md
